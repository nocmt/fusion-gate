{
  "_comment": "==== FusionGate Example Config ====\n* = 必填    ⓟ = 自动从定价库填充(可省略)    无标记 = 可选(有默认值)\n",
  "providers": [
    {
      "_comment": "场景 A: 极简配置 — 只填 4 个必填字段，其余自动补全（推荐！）",
      "name": "deepseek", "*": true,
      "base_url": "https://api.deepseek.com/v1", "*": true,
      "model_name": "deepseek-chat", "*": true,
      "api_key": "sk-xxxxxxxxxxxxxxxx", "*": true,
      "context_length": "ⓟ 自动填充",
      "output_length": "ⓟ 自动填充",
      "input_token_price": "ⓟ 自动填充",
      "cached_token_price": "ⓟ 自动填充",
      "output_token_price": "ⓟ 自动填充"
    },
    {
      "_comment": "场景 B: 上游是 Responses API 格式（如第三方中转站）",
      "name": "openai", "*": true,
      "base_url": "https://api.openai.com/v1", "*": true,
      "type": "responses",
      "model_name": "gpt-5.4", "*": true,
      "api_key": "sk-xxxxxxxxxxxxxxxx", "*": true
    },
    {
      "_comment": "场景 C: 自定义完整 URL（最高优先级，覆盖 base_url+type）",
      "name": "custom-proxy", "*": true,
      "full_url": "https://my-proxy.example.com/v1/chat/completions",
      "model_name": "proxy-model", "*": true,
      "api_key": "sk-xxxxxxxxxxxxxxxx", "*": true
    },
    {
      "_comment": "场景 D: 本地 Ollama（免费，价格填 0 或靠自动填充）",
      "name": "local",
      "base_url": "http://localhost:11434/v1", "*": true,
      "type": "chat",
      "model_name": "qwen2.5-coder:7b", "*": true,
      "api_key": "ollama", "*": true,
      "input_token_price": 0,
      "cached_token_price": 0,
      "output_token_price": 0
    }
  ],
  "groups": [
    {
      "_comment": "审查模型不在 providers 里 → 只负责审核",
      "name": "coding_expert", "*": true,
      "reviewer": "deepseek", "*": true,
      "providers": ["openai", "custom-proxy", "local"], "*": true
    },
    {
      "_comment": "审查模型也在 providers 里 → 自己也出一份分析",
      "name": "full_team", "*": true,
      "reviewer": "openai", "*": true,
      "providers": ["deepseek", "openai", "custom-proxy"], "*": true
    },
    {
      "_comment": "单模型测试用（providers 为空 → 直通 reviewer）",
      "name": "single", "*": true,
      "reviewer": "deepseek", "*": true,
      "providers": [], "*": true
    }
  ],
  "_pricing_note": "定价库源自 LiteLLM (2400+ 模型)，启动时自动拉取并缓存。",
  "_auto_fill_fields": "context_length, output_length, input_token_price, cached_token_price, output_token_price",
  "pricing_cache_ttl": "72h",
  "session": {
    "enabled": true,
    "ttl": "1h"
  },
  "log_level": "info",
  "cli": {
    "language": "zh-CN",
    "port": 8086,
    "host": "0.0.0.0"
  }
}
