{
  "_comment": "==== FusionGate Example Config ====\n字段标记: *必填  不带星号=可选(有默认值)\n",
  "providers": [
    {
      "_comment": "场景 A: 默认 Chat Completions API（最常用）",
      "name": "deepseek",
      "base_url": "https://api.deepseek.com/v1",
      "model_name": "deepseek-chat",
      "api_key": "sk-xxxxxxxxxxxxxxxx",
      "context_length": 65536,
      "output_length": 8192,
      "input_token_price": 0.000001,
      "cached_token_price": 0.0000005,
      "output_token_price": 0.000002
    },
    {
      "_comment": "场景 B: 上游是 Responses API 格式（如第三方中转站）",
      "name": "openai",
      "base_url": "https://api.openai.com/v1",
      "type": "responses",
      "model_name": "gpt-5.4",
      "api_key": "sk-xxxxxxxxxxxxxxxx",
      "context_length": 262144,
      "output_length": 16384,
      "input_token_price": 2.50,
      "cached_token_price": 1.25,
      "output_token_price": 10.00
    },
    {
      "_comment": "场景 C: 自定义完整 URL（最高优先级，覆盖 base_url+type）",
      "name": "custom-proxy",
      "full_url": "https://my-proxy.example.com/v1/chat/completions",
      "model_name": "proxy-model",
      "api_key": "sk-xxxxxxxxxxxxxxxx",
      "context_length": 131072,
      "output_length": 8192,
      "input_token_price": 0.50,
      "cached_token_price": 0.25,
      "output_token_price": 2.00
    },
    {
      "_comment": "场景 D: 本地 Ollama",
      "name": "local",
      "base_url": "http://localhost:11434/v1",
      "type": "chat",
      "model_name": "qwen2.5-coder:7b",
      "api_key": "ollama",
      "context_length": 32768,
      "output_length": 4096,
      "input_token_price": 0,
      "cached_token_price": 0,
      "output_token_price": 0
    }
  ],
  "groups": [
    {
      "_comment": "审查模型和子模型是独立的两组：reviewer 不在 providers 里也能正常工作",
      "name": "coding_expert",
      "reviewer": "deepseek",
      "providers": ["deepseek", "openai", "local"]
    },
    {
      "_comment": "reviewer 也在 providers 里 → 审查模型自己也出一份分析",
      "name": "full_team",
      "reviewer": "openai",
      "providers": ["deepseek", "openai", "custom-proxy"]
    },
    {
      "_comment": "单模型对比测试用（providers 为空 → 直通 reviewer）",
      "name": "single",
      "reviewer": "deepseek",
      "providers": []
    }
  ],
  "session": {
    "_comment": "previous_response_id 多轮对话映射，可省略",
    "enabled": true,
    "ttl": "1h"
  },
  "log_level": "info",
  "cli": {
    "_comment": "可全部省略",
    "language": "zh-CN",
    "port": 8086,
    "host": "0.0.0.0"
  }
}
